{
  "name": "67header",
  "displayName": "42 - 67 Header",
  "description": "42/67 Header for VSCode : www.42.fr",
  "version": "0.42.7",
  "publisher": "kube",
  "icon": "42.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/hactazia/42-67-header"
  },
  "bugs": {
    "url": "https://github.com/hactazia/42-67-header/issues"
  },
  "homepage": "https://github.com/hactazia/42-67-header",
  "license": "MIT",
  "engines": {
    "vscode": "^1.6.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/src/extension",
  "contributes": {
    "configuration": {
      "properties": {
        "42header.username": {
          "type": "string",
          "description": "Username to use in 67 headers"
        },
        "42header.email": {
          "type": "string",
          "description": "Email address to use in 67 headers"
        },
        "42header.domain": {
          "type": "string",
          "description": "Domain to use in 67 headers"
        }
      }
    },
    "commands": [
      {
        "command": "42header.insertHeader",
        "title": "Insert 67 header",
        "when": "editorTextFocus"
      }
    ],
    "keybindings": [
      {
        "command": "42header.insertHeader",
        "key": "ctrl+alt+h",
        "mac": "cmd+alt+h",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.6.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "moment": "^2.15.0"
  }
}
